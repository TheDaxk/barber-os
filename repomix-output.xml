            Icon(Icons.cut_rounded, size: 64, color: Colors.white),
            SizedBox(height: 16),
            Text(
              'BarberOS',
              style: TextStyle(
                fontSize: 28,
                fontWeight: FontWeight.bold,
                color: Colors.white,
              ),
            ),
            SizedBox(height: 32),
            CircularProgressIndicator(color: Colors.white),
          ],
        ),
      ),
    );
  }
}
